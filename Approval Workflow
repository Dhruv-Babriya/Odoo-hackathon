<!DOCTYPE html>
<html>
<head>
    <title>Approval Workflow</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: #F2E1C3;
            margin: 0;
            padding: 20px;
            min-height:100vh;
        }

        body::before{
            content:"";
            position:fixed;
            inset:0;
            background:
              radial-gradient(circle at 10% 10%, rgba(37, 99, 235, 0.10), transparent 40%),
              radial-gradient(circle at 90% 30%, rgba(16, 185, 129, 0.10), transparent 45%);
            pointer-events:none;
            z-index:-1;
        }

        .container {
            max-width: 1050px;
            margin: auto;
        }

        .card {
            background: white;
            padding: 22px;
            margin-bottom: 18px;
            border-radius: 16px;
            box-shadow: 0px 6px 22px rgba(0,0,0,0.08);
            border:1px solid rgba(229,231,235,0.8);
        }

        h1 {
            text-align: center;
            color: #111827;
            font-size: 28px;
            font-weight: 900;
            margin: 18px 0 22px;
        }

        h2 {
            color: #1f2937;
            border-bottom: 2px solid #e5e7eb;
            padding-bottom: 10px;
            margin-bottom: 15px;
            font-weight: 900;
        }

        label {
            font-weight: 900;
            color:#374151;
        }

        textarea {
            width: 100%;
            height: 80px;
            padding: 12px;
            margin-top: 10px;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            outline:none;
        }

        textarea:focus{
            border-color:#93c5fd;
            box-shadow:0 0 0 3px rgba(59,130,246,0.15);
        }

        .btn {
            padding: 12px 18px;
            margin-top: 15px;
            border: none;
            color: white;
            cursor: pointer;
            border-radius: 12px;
            font-weight: 900;
            margin-right:10px;
        }

        .approve { background-color: #22c55e; }
        .reject { background-color: #ef4444; }

        .approve:hover{ background:#16a34a; }
        .reject:hover{ background:#dc2626; }

        .status {
            display: inline-block;
            padding: 8px 14px;
            border-radius: 999px;
            color: white;
            font-weight: 900;
            font-size: 12px;
        }

        .pending { background-color: #f59e0b; }
        .approved { background-color: #10b981; }

        .timeline {
            list-style: none;
            padding: 0;
        }

        .timeline li {
            background: #f9fafb;
            margin-bottom: 10px;
            padding: 12px;
            border-left: 6px solid #2563eb;
            border-radius: 12px;
            font-weight: 700;
            color:#111827;
        }

        .workflow {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
            gap:10px;
            flex-wrap:wrap;
        }

        .step {
            flex: 1;
            min-width: 190px;
            text-align: center;
            padding: 14px;
            background: #f3f4f6;
            border-radius: 14px;
            font-weight: 900;
            color:#374151;
        }

        .active {
            background: #2563eb;
            color: white;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th,
        table td {
            border: 1px solid #e5e7eb;
            padding: 12px;
            text-align: left;
        }

        table th {
            background: #111827;
            color: white;
        }
    </style>
</head>
<body>

<div class="container">

    <h1>Approval Workflow</h1>

    <div class="card">
        <h2>Approve / Reject Request</h2>

        <p><strong>Request ID:</strong> PR-1001</p>
        <p><strong>Requested By:</strong> Procurement Team</p>

        <label>Approval Remarks</label>
        <textarea placeholder="Enter your remarks here..."></textarea>

        <br>

        <button class="btn approve" onclick="decideApproval(true)">Approve</button>
        <button class="btn reject" onclick="decideApproval(false)">Reject</button>
    </div>

    <div class="card">
        <h2>Status Tracking</h2>

        <p>
            Current Status:
            <span class="status pending">Pending Approval</span>
        </p>
    </div>

    <div class="card">
        <h2>Workflow State Transitions</h2>

        <div class="workflow">
            <div class="step">Submitted</div>
            <div class="step active">Manager Approval</div>
            <div class="step">Finance Approval</div>
            <div class="step">Completed</div>
        </div>
    </div>

    <div class="card">
        <h2>Approval Timeline</h2>

        <ul class="timeline">
            <li>09:00 AM - Purchase Request Submitted</li>
            <li>10:30 AM - Sent to Manager for Approval</li>
            <li>11:00 AM - Under Review</li>
        </ul>
    </div>

    <div class="card">
        <h2>Approval Audit Log</h2>

        <table>
            <tr>
                <th>Date & Time</th>
                <th>User</th>
                <th>Action</th>
                <th>Remarks</th>
            </tr>

            <tr>
                <td>06-06-2026 09:00 AM</td>
                <td>Employee</td>
                <td>Submitted Request</td>
                <td>Purchase of laptops</td>
            </tr>

            <tr>
                <td>06-06-2026 10:30 AM</td>
                <td>System</td>
                <td>Forwarded for Approval</td>
                <td>Manager Review Required</td>
            </tr>
        </table>
    </div>

</div>

<script>
function decideApproval(isApproved){
    if(!requireStep('APPROVAL', 'flow.selectedQuotation')){
        return;
    }

    const remarksEl = document.querySelector('textarea');
    const remarks = (remarksEl && remarksEl.value ? remarksEl.value.trim() : '');

    setFlowState('flow.approvalDecision', {
        decision: isApproved ? 'APPROVED' : 'REJECTED',
        remarks,
        decidedAt: new Date().toISOString()
    });

    if(isApproved){
        requireStep('PURCHASE', 'flow.approvalDecision');
        window.location = 'purchase.html';
    }else{
        alert('Request rejected. Flow stopped.');
        window.location = 'activity.html';
    }
}
</script>

</body>
</html>

