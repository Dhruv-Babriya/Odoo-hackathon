<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VendorBridge - Purchase Order & Invoice</title>

<style>
  *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial,sans-serif;
  }

  body{
      background:#F2E1C3;
      padding:20px;
      min-height:100vh;
      position:relative;
  }

  body::before{
      content:"";
      position:fixed;
      inset:0;
      background:
        radial-gradient(circle at 10% 10%, rgba(37, 99, 235, 0.10), transparent 40%),
        radial-gradient(circle at 90% 30%, rgba(16, 185, 129, 0.10), transparent 45%);
      pointer-events:none;
      z-index:-1;
  }

  .container{
      max-width:1100px;
      margin:0 auto;
  }

  .card{
      background:white;
      padding:22px;
      border-radius:16px;
      margin-bottom:20px;
      box-shadow:0 6px 22px rgba(0,0,0,0.08);
  }

  h1,h2{
      margin-bottom:15px;
      color:#1f2937;
  }

  .form-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:15px;
  }

  label{
      display:block;
      font-weight:900;
      color:#374151;
      margin-bottom:6px;
  }

  input,select{
      width:100%;
      padding:11px 12px;
      border:1px solid #e5e7eb;
      border-radius:12px;
      outline:none;
  }

  input:focus,select:focus{
      border-color:#93c5fd;
      box-shadow:0 0 0 3px rgba(59,130,246,0.15);
  }

  .btn-row{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin:14px 0 6px;
  }

  button{
      background:#2563eb;
      color:white;
      border:none;
      padding:12px 16px;
      border-radius:12px;
      cursor:pointer;
      font-weight:900;
  }

  button:hover{ background:#1d4ed8; }

  .invoice-box{
      border:1px solid #e5e7eb;
      padding:18px;
      border-radius:14px;
      background:#fbfdff;
  }

  .status{
      padding:8px 12px;
      border-radius:12px;
      color:white;
      display:inline-block;
      font-weight:900;
      font-size:12px;
  }

  .draft{ background:#f59e0b; }
  .generated{ background:#10b981; }
  .sent{ background:#2563eb; }

  table{
      width:100%;
      border-collapse:collapse;
      margin-top:10px;
  }

  table th, table td{
      border:1px solid #e5e7eb;
      padding:10px;
      text-align:left;
      color:#111827;
  }

  table th{ background:#f3f4f6; }

  @media(max-width:768px){
      .form-grid{ grid-template-columns:1fr; }
  }
</style>
</head>

<body>

<div class="container">

    <div class="card">
        <h1>Purchase Order & Invoice Generation</h1>

        <div class="form-grid">
            <div>
                <label>PO Number</label>
                <input type="text" id="poNumber" readonly>
            </div>

            <div>
                <label>Vendor Name</label>
                <input type="text" id="vendorName">
            </div>

            <div>
                <label>Item Name</label>
                <input type="text" id="itemName">
            </div>

            <div>
                <label>Quantity</label>
                <input type="number" id="quantity" min="1">
            </div>

            <div>
                <label>Unit Price (₹)</label>
                <input type="number" id="unitPrice" min="0">
            </div>

            <div>
                <label>Status</label>
                <select id="status">
                    <option>Draft</option>
                    <option>Generated</option>
                    <option>Sent</option>
                </select>
            </div>

            <div style="grid-column: 1 / -1;">
                <label>Email</label>
                <input type="email" id="email">
            </div>
        </div>

        <div class="btn-row">
            <button type="button" onclick="generateInvoice()">Generate Invoice</button>
            <button type="button" onclick="printInvoice()">Print Invoice</button>
            <button type="button" onclick="sendEmail()">Send Invoice</button>
        </div>

    </div>

    <div class="card">
        <h2>Invoice Preview</h2>

        <div id="invoiceArea">
            <p>
                Status:
                <span id="statusBadge" class="status draft">Draft</span>
            </p>

            <div class="invoice-box">
                <h2 style="margin-bottom:10px;">VendorBridge ERP Invoice</h2>

                <p><strong>PO Number:</strong> <span id="showPo"></span></p>
                <p><strong>Vendor:</strong> <span id="showVendor"></span></p>

                <table>
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Unit Price</th>
                            <th>Total</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td id="showItem"></td>
                            <td id="showQty"></td>
                            <td id="showUnit"></td>
                            <td id="showSub"></td>
                        </tr>
                    </tbody>
                </table>

                <br>

                <p><strong>Subtotal:</strong> ₹<span id="subtotal">0</span></p>
                <p><strong>GST (18%):</strong> ₹<span id="gst">0</span></p>
                <p><strong>Grand Total:</strong> ₹<span id="grandTotal">0</span></p>
            </div>
        </div>

    </div>

</div>

<script>
const poNumber =
"PO-" +
new Date().getFullYear() +
"-" +
Math.floor(1000 + Math.random()*9000);

document.getElementById("poNumber").value = poNumber;

document.getElementById("showPo").innerText = poNumber;

function generateInvoice(){

if(!requireStep('PURCHASE', 'flow.approvalDecision')){
    return;
}

const vendor =
document.getElementById("vendorName").value.trim();

const item =
document.getElementById("itemName").value.trim();

const qty =
parseFloat(document.getElementById("quantity").value);

const unit =
parseFloat(document.getElementById("unitPrice").value);

const status =
document.getElementById("status").value;

if(
vendor === "" ||
item === "" ||
isNaN(qty) ||
isNaN(unit)
){
alert("Please fill all fields");
return;
}

const subtotal = qty * unit;
const gst = subtotal * 0.18;
const total = subtotal + gst;

document.getElementById("showVendor").innerText = vendor;

document.getElementById("showItem").innerText = item;

document.getElementById("showQty").innerText = qty;

document.getElementById("showUnit").innerText = "₹" + unit.toFixed(2);

document.getElementById("showSub").innerText = "₹" + subtotal.toFixed(2);

document.getElementById("subtotal").innerText =
subtotal.toFixed(2);

document.getElementById("gst").innerText =
gst.toFixed(2);

document.getElementById("grandTotal").innerText =
total.toFixed(2);

const badge =
document.getElementById("statusBadge");

badge.innerText = status;

badge.className = "status";

if(status === "Draft"){
badge.classList.add("draft");
}

if(status === "Generated"){
badge.classList.add("generated");
}

if(status === "Sent"){
badge.classList.add("sent");
}

alert("Invoice Generated Successfully");

// Save PO/invoice state for activity page
const selectedQuotation = getFlowState('flow.selectedQuotation') || {};
setFlowState('flow.generatedPO', {
    poNumber: document.getElementById('poNumber').value,
    vendor,
    item: document.getElementById('itemName').value.trim(),
    qty: parseFloat(document.getElementById('quantity').value),
    unitPrice: parseFloat(document.getElementById('unitPrice').value),
    status,
    invoiceTotal: document.getElementById('grandTotal').innerText,
    linkedQuotationNo: selectedQuotation.quotationNo,
    generatedAt: new Date().toISOString()
});

requireStep('ACTIVITY', 'flow.generatedPO');
window.location = 'activity.html';

}


function printInvoice(){
window.print();
}

function sendEmail(){

const email =
document.getElementById("email").value.trim();

if(email === ""){
alert("Enter Email Address");
return;
}

const total =
document.getElementById("grandTotal").innerText;

const po =
document.getElementById("poNumber").value;

const subject =
encodeURIComponent("Invoice " + po);

const body =
encodeURIComponent(
"Purchase Order: " + po +
"\nInvoice Total: ₹" + total +
"\nGenerated from VendorBridge ERP"
);

window.location.href =
"mailto:" +
email +
"?subject=" +
subject +
"&body=" +
body;

}

</script>

</body>
</html>

