<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VendorBridge ERP Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background: #F2E1C3;
}

/* subtle page background texture */
body::before{
    content:"";
    position:fixed;
    inset:0;
    background:
      radial-gradient(circle at 10% 10%, rgba(37, 99, 235, 0.10), transparent 40%),
      radial-gradient(circle at 90% 30%, rgba(16, 185, 129, 0.10), transparent 45%);
    pointer-events:none;
    z-index:-1;
}

.header{
    background: linear-gradient(135deg, #111827 0%, #2563eb 100%);
    color:white;
    padding:16px 30px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}

.header h1{
    font-size:24px;
}

.profile{
    font-size:14px;
}

.container{
    padding:20px;
}

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    margin-bottom:30px;
}

.card{
    background:white;
    padding:20px;
    border-radius:10px;
    box-shadow:0 2px 8px rgba(0,0,0,0.1);
}

.card h3{
    color:#666;
    margin-bottom:10px;
}

.card .value{
    font-size:28px;
    font-weight:bold;
    color:#111827;
}

.quick-actions{
    margin-bottom:30px;
}

.quick-actions h2{
    margin-bottom:15px;
}

.action-buttons{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
}

.action-buttons button{
    padding:12px 20px;
    border:none;
    background:#2563eb;
    color:white;
    border-radius:6px;
    cursor:pointer;
    transition:0.3s;
}

.action-buttons button:hover{
    background:#1d4ed8;
}

.section{
    background:white;
    padding:20px;
    margin-bottom:25px;
    border-radius:10px;
    box-shadow:0 2px 8px rgba(0,0,0,0.1);
}

.section h2{
    margin-bottom:15px;
}

table{
    width:100%;
    border-collapse:collapse;
}

table th{
    background:#e5e7eb;
    padding:12px;
    text-align:left;
}

table td{
    padding:12px;
    border-bottom:1px solid #ddd;
}

.status{
    padding:5px 10px;
    border-radius:5px;
    color:white;
    font-size:12px;
}

.pending{
    background:#f59e0b;
}

.approved{
    background:#10b981;
}

.sent{
    background:#3b82f6;
}

.timeline{
    list-style:none;
}

.timeline li{
    padding:10px;
    border-left:4px solid #2563eb;
    margin-bottom:10px;
    background:#f9fafb;
}

.footer{
    text-align:center;
    padding:22px;
    color:#6b7280;
}

/* small responsive improvements */
@media (max-width: 640px){
    .header{padding:12px 14px;}
    .container{padding:14px;}
    .cards{gap:14px;}
    .section{padding:16px;}
    table th, table td{padding:10px;}
}
</style>
</head>

<body>

<div class="header">
    <h1>VendorBridge ERP Dashboard</h1>
    <div class="profile">
        Welcome, Admin
    </div>
</div>

<div class="container">

    <div class="cards">

        <div class="card">
            <h3>Pending Approvals</h3>
            <div class="value" id="approvals">12</div>
        </div>

        <div class="card">
            <h3>Active RFQs</h3>
            <div class="value" id="rfqs">25</div>
        </div>

        <div class="card">
            <h3>Purchase Orders</h3>
            <div class="value">85</div>
        </div>

        <div class="card">
            <h3>Invoices</h3>
            <div class="value">63</div>
        </div>

        <div class="card">
            <h3>Active Vendors</h3>
            <div class="value">420</div>
        </div>

        <div class="card">
            <h3>Total Spend</h3>
            <div class="value">₹1.2 Cr</div>
        </div>

    </div>

    <div class="quick-actions">
        <h2>Quick Actions</h2>

        <div class="action-buttons">
            <button onclick="window.location='vendorManagement.html'">Vendor Management</button>
            <button onclick="window.location='RFQcreation.html'">Create RFQ</button>


            <button onclick="window.location='purchase.html'">Purchase</button>

            <button onclick="window.location='activity.html'">Activity</button>
            <button onclick="window.location='vendorQuotation.html'">Vendor Quotation</button>
            <button onclick="window.location='QuotationComparison.html'">Quotation Comparison</button>
            <button onclick="window.location='approval.html'">Approval</button>
            <button onclick="window.location='report.html'">Report</button>



        </div>
    </div>

    <div class="section">
        <h2>Pending Approvals</h2>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Type</th>
                    <th>Vendor</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td>APR-101</td>
                    <td>RFQ</td>
                    <td>ABC Traders</td>
                    <td>₹50,000</td>
                    <td><span class="status pending">Pending</span></td>
                </tr>

                <tr>
                    <td>APR-102</td>
                    <td>PO</td>
                    <td>XYZ Industries</td>
                    <td>₹2,20,000</td>
                    <td><span class="status pending">Pending</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Recent Purchase Orders</h2>

        <table>
            <thead>
                <tr>
                    <th>PO Number</th>
                    <th>Vendor</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td>PO-1001</td>
                    <td>ABC Traders</td>
                    <td>₹1,20,000</td>
                    <td><span class="status approved">Issued</span></td>
                </tr>

                <tr>
                    <td>PO-1002</td>
                    <td>Tech Solutions</td>
                    <td>₹3,50,000</td>
                    <td><span class="status approved">Delivered</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Recent Invoices</h2>

        <table>
            <thead>
                <tr>
                    <th>Invoice No</th>
                    <th>Vendor</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td>INV-201</td>
                    <td>ABC Traders</td>
                    <td>₹1,20,000</td>
                    <td><span class="status sent">Sent</span></td>
                </tr>

                <tr>
                    <td>INV-202</td>
                    <td>Tech Solutions</td>
                    <td>₹3,50,000</td>
                    <td><span class="status approved">Paid</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Procurement Activity Timeline</h2>

        <ul class="timeline">
            <li>10:30 AM - RFQ-501 Created</li>
            <li>11:00 AM - Vendor ABC Submitted Quotation</li>
            <li>12:45 PM - PO-1001 Approved</li>
            <li>02:10 PM - Invoice INV-201 Generated</li>
        </ul>
    </div>

</div>

<div class="footer">
    VendorBridge ERP © 2026
</div>

<script>

function showMessage(action){
    alert(action + " clicked!");
}

setInterval(() => {
    let approvals = document.getElementById("approvals");
    let current = parseInt(approvals.innerText);

    if(current > 0){
        approvals.innerText = current - 1;
    }
}, 10000);

</script>

</body>
</html>
